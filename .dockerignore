# 1. Deny Everything Default
*

# 2. Whitelist ONLY files explicitly requested by `Dockerfile`
!package.json
!bun.lock
!package-lock.json*
!nx.json
!docker-entrypoint.sh
!tsconfig.base.json
!tsconfig.json
!eslint.config.mjs
