{
  "name": "fibe-agent",
  "version": "1.13.7",
  "license": "MIT",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "postinstall": "find node_modules -type f -name 'spawn-helper' -exec chmod +x {} +",
    "dev": "nx run-many -t serve,dev --parallel=2",
    "build": "nx run-many -t build --parallel=3",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "test:integration": "echo 'No integration tests configured'",
    "typecheck": "nx run-many -t typecheck",
    "e2e": "nx run-many -t e2e",
    "ci": "nx run-many -t lint,build,typecheck,test",
    "ci:notest": "nx run-many -t lint,build,typecheck"
  },
  "private": true,
