# API (Nest) – used when running `nx serve api`
PORT=3000
# Comma-separated allowed CORS origins (default: http://localhost:3100, http://localhost:4300)
# CORS_ORIGINS=https://app.example.com,https://www.example.com
AGENT_PASSWORD=
AGENT_PROVIDER=gemini
MODEL_OPTIONS=flash-lite,flash,pro
# DEFAULT_MODEL=flash
DATA_DIR=
SYSTEM_PROMPT_PATH=

# Optional: provider session dir (e.g. in Docker)
# SESSION_DIR=/home/node/.gemini

# Stored Agent credentials (injected by Phoenix when attaching a stored Agent)
# AGENT_CREDENTIALS_JSON={"agent_token.txt":"sk-ant-..."}
# SESSION_DIR must be set when using AGENT_CREDENTIALS_JSON

# Chat (Vite) – optional; only if API is on another origin
# VITE_API_URL=http://localhost:3000
# Set to lock the model selector (disabled input showing model in use, e.g. when model is fixed by backend/env)
# VITE_LOCK_CHAT_MODEL=true
