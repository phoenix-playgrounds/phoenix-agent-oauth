# API (Nest) – used when running `nx serve api`
PORT=3000
AGENT_PASSWORD=
AGENT_PROVIDER=gemini
MODEL_OPTIONS=flash-lite,flash,pro
DATA_DIR=
SYSTEM_PROMPT_PATH=

# Optional: Gemini strategy (e.g. in Docker)
# SESSION_DIR=/home/node/.gemini

# Chat (Vite) – optional; only if API is on another origin
# VITE_API_URL=http://localhost:3000
