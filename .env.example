# API (Nest) – used when running `nx serve api`
PORT=3000
# Comma-separated allowed CORS origins (default: http://localhost:3100, http://localhost:4300). Use * to allow any (e.g. when embedding chat in iframe).
# CORS_ORIGINS=https://app.example.com,https://www.example.com
# Comma-separated allowed frame ancestors for CSP (default: * so chat can be embedded in iframe). Restrict in production.
# FRAME_ANCESTORS=https://parent.example.com
AGENT_PASSWORD=
AGENT_PROVIDER=gemini
# Available providers: gemini, claude-code, openai-codex, opencode
MODEL_OPTIONS=flash-lite,flash,pro
# DEFAULT_MODEL=flash
DATA_DIR=
SYSTEM_PROMPT_PATH=

# Conversation context: when set, messages, activities, uploads, and provider sessions are stored per conversation (under DATA_DIR/<id>/). Same agent id = same conversation across restarts.
# FIBE_AGENT_ID=      # Set by Fibe when attaching a stored agent
# CONVERSATION_ID=    # Optional fallback for non-Fibe multi-conversation

# --- OpenCode provider examples (set AGENT_PROVIDER=opencode) ---
# OpenCode auto-detects the provider from whichever API key env var is set.
# No auth modal is shown when the API key is provided via env.
# Use `opencode models [provider]` to list available model IDs.
#
# OpenRouter (any model via unified key):
#   OPENROUTER_API_KEY=sk-or-...
#   MODEL_OPTIONS=openrouter/anthropic/claude-sonnet-4,openrouter/openai/gpt-4.1,openrouter/google/gemini-2.5-pro
#
# Anthropic direct:
#   ANTHROPIC_API_KEY=sk-ant-...
#   MODEL_OPTIONS=anthropic/claude-sonnet-4,anthropic/claude-haiku-4
#
# OpenAI direct:
#   OPENAI_API_KEY=sk-...
#   MODEL_OPTIONS=openai/gpt-4.1,openai/gpt-4.1-mini,openai/o3
#
# Google Gemini direct:
#   GEMINI_API_KEY=AIza...
#   MODEL_OPTIONS=google/gemini-2.5-pro,google/gemini-2.5-flash
#
# No env key → auth modal appears; user pastes key at runtime.

# Optional: provider session dir (e.g. in Docker). Must match provider config dir for credential injection.
# Gemini: SESSION_DIR=/home/node/.gemini
# OpenAI Codex (OAuth device flow only): SESSION_DIR=/home/node/.codex

# Stored Agent credentials (injected by Phoenix when attaching a stored Agent)
# AGENT_CREDENTIALS_JSON={"agent_token.txt":"sk-ant-..."}
# For opencode: AGENT_CREDENTIALS_JSON={"auth.json":"{\"api_key\":\"sk-...\"}"}
# For openai-codex (OAuth token only): AGENT_CREDENTIALS_JSON={"auth.json":"{\"access_token\":\"...\"}"} and SESSION_DIR
# SESSION_DIR must be set when using AGENT_CREDENTIALS_JSON

# Chat (Vite) – optional; only if API is on another origin
# API_URL=http://localhost:3000
# Set to lock the model selector (disabled input showing model in use, e.g. when model is fixed by backend/env)
# LOCK_CHAT_MODEL=true
# Optional: URL for the assistant's avatar in the chat (the bot/AI side)
# ASSISTANT_AVATAR_URL=https://example.com/assistant.png
# Optional: URL for the user's avatar in the chat (the person chatting)
# USER_AVATAR_URL=https://example.com/user.png
