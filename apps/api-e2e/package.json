{
  "name": "@playgrounds.dev/api-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "name": "api-e2e",
    "implicitDependencies": [
      "api"
    ],
    "targets": {
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc -p tsconfig.typecheck.json --noEmit",
          "cwd": "apps/api-e2e"
        }
      },
      "e2e": {
        "executor": "nx:run-commands",
        "options": {
          "command": "sh -c '(cd ../api && node dist/main.js) & sleep 3 && bun test --preload ./src/support/test-setup.ts'",
          "cwd": "apps/api-e2e"
        },
        "dependsOn": [
          "api:build:development"
        ]
      }
    }
  }
}
