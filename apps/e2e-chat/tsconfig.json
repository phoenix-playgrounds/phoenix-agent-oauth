{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "out-tsc",
    "allowJs": true,
    "types": ["node", "@playwright/test"],
    "sourceMap": false
  },
  "include": [
    "**/*.ts",
    "**/*.js",
    "playwright.config.ts",
    "**/*.spec.ts",
    "**/*.d.ts"
  ],
  "exclude": [
    "out-tsc",
    "test-results",
    "playwright-report",
    "eslint.config.mjs"
  ]
}
