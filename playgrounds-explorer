#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');

function showHelp() {
  console.log(`Usage: ./playgrounds-explorer [{PLAYGROUND_NAME}] [OPTIONS]

A CLI utility to explore local Playgrounds.

Options:
  --urls        Output only the service URLs for the specified playground
  --link        Link the specified playground to /app/playground
  --help, -h    Show this help message

Environment Variables:
  PLAYROOMS_ROOT  Directory containing the playgrounds (default: /opt/fibe/playgrounds)
  MARQUEE_ROOT_DOMAIN Base domain for URLs

Examples:
  ./playgrounds-explorer                    # List all playgrounds
  ./playgrounds-explorer {PLAYGROUND_NAME}          # Show extended info for '{PLAYGROUND_NAME}'
  ./playgrounds-explorer {PLAYGROUND_NAME} --urls   # Output service URLs (e.g. web-123.\${MARQUEE_ROOT_DOMAIN:-phoenix.test})
  ./playgrounds-explorer {PLAYGROUND_NAME} --link   # Map playground directories into /app/playground
`);
}

const args = process.argv.slice(2);

if (args.includes('--help') || args.includes('-h')) {
  showHelp();
  process.exit(0);
}

let action = 'LIST';
let target = '';
let showUrls = false;
let doLink = false;

if (args.includes('--urls')) {
  showUrls = true;
}

if (args.includes('--link')) {
  doLink = true;
}

let linkDir;
const linkDirIdx = args.indexOf('--link-dir');
if (linkDirIdx !== -1) {
  linkDir = args[linkDirIdx + 1];
}

const cleanArgs = args.filter(a => a !== '--urls' && a !== '--link' && a !== '--help' && a !== '-h' && a !== '--link-dir' && a !== linkDir);

if (cleanArgs.length > 0) {
  action = 'INFO';
  target = cleanArgs[0];
} else if (showUrls) {
  action = 'INFO';
  target = '';
}

if (doLink) {
  action = 'LINK';
  target = cleanArgs[0];
  if (!target) {
    console.error("Error: --link requires a target playground name");
    process.exit(1);
  }
}

const baseDir = process.env.PLAYROOMS_ROOT || '/opt/fibe/playgrounds';
const rootDomain = process.env.MARQUEE_ROOT_DOMAIN || 'phoenix.test';

if (!fs.existsSync(baseDir)) {
  console.error(`Error: Directory '${baseDir}' does not exist.`);
  console.error(`You can set the PLAYROOMS_ROOT environment variable.`);
  process.exit(1);
}

const pgDirs = fs.readdirSync(baseDir, { withFileTypes: true })
  .filter(dirent => dirent.isDirectory())
  .map(dirent => dirent.name);

let foundCount = 0;

for (const pgName of pgDirs) {
  const ymlPath = path.join(baseDir, pgName, 'compose.yml');
  if (!fs.existsSync(ymlPath)) continue;

  const ymlContent = fs.readFileSync(ymlPath, 'utf8');

  // Basic playspec
  const playspecMatch = ymlContent.match(/fibe\.gg\/playspec:\s*['"]?([^\s'"]+)['"]?/);
  const playspec = playspecMatch ? playspecMatch[1] : pgName;

  if (action === 'LIST') {
      console.log(`${pgName}|${playspec}`);
      continue;
  }

  if (action === 'INFO' || action === 'LINK') {
    if (pgName === target || playspec === target || playspec.startsWith(target)) {
      foundCount++;
      
      const lines = ymlContent.split('\n');
      let currentService = null;
      let inServices = false;
      const services = {};
      
      for (const line of lines) {
        if (/^services:/.test(line)) {
            inServices = true;
            continue;
        }
        if (inServices && /^[a-zA-Z]/.test(line)) {
            inServices = false;
        }
        
        if (inServices) {
            const svcMatch = line.match(/^  ([a-zA-Z0-9_-]+):/);
            if (svcMatch) {
              currentService = svcMatch[1];
              services[currentService] = { name: currentService };
            } else if (currentService) {
              const imageMatch = line.match(/^\s+image:\s+['"]?([^'"]+)['"]?/);
              if (imageMatch) services[currentService].image = imageMatch[1];

              if (line.match(/traefik\.enable:\s+['"]?true['"]?/)) services[currentService].traefik = true;
              if (line.match(/fibe\.gg\/expose:/)) services[currentService].expose = true;
              
              const subMatch = line.match(/fibe\.gg\/subdomain:\s+['"]?([^'"]+)['"]?/);
              if (subMatch) services[currentService].subdomain = subMatch[1];

              const cmdMatch = line.match(/fibe\.gg\/start_command:\s+(.+)$/);
              if (cmdMatch) {
                  let cmd = cmdMatch[1].trim();
                  cmd = cmd.replace(/^["']/, '').replace(/["']$/, '');
                  services[currentService].startCmd = cmd;
              }

              const volLineMatch = line.match(/^\s*-\s*["']?(\/opt\/fibe[^:"']+)[:"']/);
              if (volLineMatch) {
                  const hostPath = volLineMatch[1];
                  const propsIdx = hostPath.indexOf('/props/');
                  if (propsIdx !== -1) {
                      const relative = hostPath.substring(propsIdx + 7);
                      const parts = relative.split('/');
                      if (parts.length >= 2) {
                          services[currentService].hostMount = hostPath;
                          services[currentService].branch = parts[1];
                      }
                  }
              }
            }
        }
      }

      if (action === 'LINK') {
          console.log(`Linking ${pgName}...`);
          const targetDir = typeof linkDir === 'string' ? linkDir : '/app/playground';
          
          if (fs.existsSync(targetDir)) {
             try {
                 const st = fs.lstatSync(targetDir);
                 if (st.isSymbolicLink()) {
                     fs.unlinkSync(targetDir);
                 } else {
                     fs.rmSync(targetDir, { recursive: true, force: true });
                 }
             } catch(e) {}
          }
          fs.mkdirSync(targetDir, { recursive: true });

          const mountableServices = Object.values(services).filter(svc => svc.hostMount);
          const uniqueBranches = new Set(mountableServices.map(svc => svc.branch));
          const appendBranch = uniqueBranches.size > 1;

          const createdMounts = new Set();
          for (const svc of mountableServices) {
              if (createdMounts.has(svc.hostMount)) continue;
              createdMounts.add(svc.hostMount);
              
              let symlinkName = svc.name;
              if (appendBranch && svc.branch) {
                  symlinkName = `${symlinkName}-${svc.branch}`;
              }
              const symlinkPath = path.join(targetDir, symlinkName);
              
              if (fs.existsSync(symlinkPath)) {
                  try { fs.rmSync(symlinkPath, { recursive: true, force: true }); } catch (e) {}
              }
              
              fs.symlinkSync(svc.hostMount, symlinkPath, 'dir');
              console.log(`Created symlink: ${symlinkPath} -> ${svc.hostMount}`);
          }
          
          // Write the state file
          const stateFile = path.join(targetDir, '.current_playground');
          fs.writeFileSync(stateFile, pgName);
          console.log(`State saved in ${stateFile}`);

          process.exit(0);
      }

      if (showUrls) {
          const seenUrls = new Set();
          for (const svcName in services) {
              const svc = services[svcName];
              if (svc.traefik && svc.subdomain) {
                  const fullUrl = `${svc.subdomain}.${rootDomain}`;
                  if (!seenUrls.has(fullUrl)) {
                      seenUrls.add(fullUrl);
                      console.log(`${svcName}|${fullUrl}`);
                  }
              }
          }
      } else {
          // Compatibility for INFO action
          let branch = 'unknown';
          let mountPath = 'unknown';
          let propFormatted = 'unknown';
          const propsMatch = ymlContent.match(/-\s*["']?(.*?\/props\/([^\/]+)\/([^\/:]+))[:"']/);
          if (propsMatch) {
            mountPath = propsMatch[1];
            let propNameRaw = propsMatch[2];
            branch = propsMatch[3];
            const propParts = propNameRaw.split('--');
            if (propParts.length >= 3) {
               propFormatted = `${propParts[0]} (id=${propParts[propParts.length - 1]})`;
            } else {
               propFormatted = propNameRaw;
            }
          }

          console.log(`==========================================================`);
          console.log(`Playground:  ${playspec}`);
          console.log(`Branch:      ${branch}`);
          console.log(`Prop:        ${propFormatted}`);
          console.log(`Mount:       ${mountPath}`);
          console.log(``);
          console.log(`Services:`);
          
          for (const svcName in services) {
              const svc = services[svcName];
              console.log(`  - ${svcName}:`);
              if (svc.image) console.log(`      Image:      ${svc.image}`);
              if (svc.traefik && svc.subdomain) {
                  console.log(`      URL:        https://${svc.subdomain}.${rootDomain}`);
              } else {
                  console.log(`      Network:    Internal only`);
              }
              if (svc.startCmd) {
                  console.log(`      Command:    ${svc.startCmd}`);
              }
              if (svc.hostMount) {
                  console.log(`      Mount:      ${svc.hostMount}`);
              }
              console.log(``);
          }
          console.log(`==========================================================`);
      }
    }
  }
}

if ((action === 'INFO' || action === 'LINK') && foundCount === 0) {
    console.error(`No playground found matching '${target}'`);
    process.exit(1);
}
